# Enigma2 receiver settings
ENIGMA2_HOST=192.168.1.100
ENIGMA2_PORT=80
ENIGMA2_STREAM_PORT=8001
ENIGMA2_USER=
ENIGMA2_PASSWORD=

# Web interface login
APP_USERNAME=admin
APP_PASSWORD=admin

# Session secret (random string, at least 32 characters)
SESSION_SECRET=please-change-this-to-a-random-string-here

FFMPEG_FORCE_VIDEO_TRANSCODE=false
FFMPEG_PROBESIZE=10000000
FFMPEG_ANALYZEDURATION=10000000
FFMPEG_TRANSCODE_PRESET=veryfast

# App port
PORT=3000
